class Complex:
	def __init__(self):
		self.real = 0
		self.imag = 0
	def initComplex(self):
		data = input().split()
		self.real = float(data[0])
		self.imag = float(data[1])
	def sum(self, c1, c2):
		self.real = c1.real + c2.real
		self.imag = c1.imag + c2.imag
	def display(self):
		sign = "+" if self.imag >= 0 else "-"
		print(f"{self.real:g} {sign} {abs(self.imag):g}i")


# Create three instances
c1 = Complex()
c2 = Complex()
c3 = Complex()

# Initialize two complex numbers
c1.initComplex()
c2.initComplex()

# Compute and display sum
c3.sum(c1, c2)
c3.display()
